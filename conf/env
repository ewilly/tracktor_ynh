# Environment Configuration
NODE_ENV="production"

# Server Configuration
BASE_URL="__PATH_ENV__"
HOST="127.0.0.1"
PORT=__PORT__

# Database Configuration
DB_PATH="__DATA_DIR__/tracktor.db"

# File Upload Configuration
UPLOADS_DIR="__DATA_DIR__/uploads"

# Application Features
TRACKTOR_DEMO_MODE=false
FORCE_DATA_SEED=false
TRACKTOR_DISABLE_AUTH=false

# CORS Configuration
CORS_ORIGINS="*"

# Logging Configuration
LOG_REQUESTS=true
LOG_LEVEL="info"
LOG_DIR="/var/log/__APP__"

# File upload limit
BODY_SIZE_LIMIT=Infinity
